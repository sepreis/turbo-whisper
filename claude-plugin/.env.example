# Turbo Whisper Plugin - TTS Configuration
# Copy this file to .env.local and fill in the values

# Required: OpenAI-compatible TTS API endpoint
# Examples:
#   OpenAI:      https://api.openai.com/v1/audio/speech
#   Local:       http://localhost:8103/v1/audio/speech
#   Remote:      http://your-server:8103/v1/audio/speech
TURBO_TTS_URL=

# Required: API key for your TTS provider
TURBO_TTS_API_KEY=

# Optional: Model and voice (defaults shown)
# TURBO_TTS_MODEL=tts-1
# TURBO_TTS_VOICE=alloy
